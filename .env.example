# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Optional API base override (use when automatic host/subdomain detection is not available)
# Examples:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_API_BASE_URL=https://your-tenant.oro-system.com
# API_BASE_URL=https://your-tenant.oro-system.com

# Optional: when running on localhost, force tenant asset fallback
# Example: NEXT_PUBLIC_DEV_TENANT_SLUG=alamalelectron

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
